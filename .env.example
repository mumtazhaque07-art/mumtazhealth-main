# Mumtaz Health - Production Environment Variables Checklist
# --------------------------------------------------------

# VERCEL SETTINGS
# Go to Vercel -> Your Project -> Settings -> Environment Variables
# Copy these from your Supabase dashboard (Project Settings -> API)
VITE_SUPABASE_URL="your-supabase-project-url"
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# SUPABASE EDGE FUNCTION SECRETS
# Run this in your terminal or add via Supabase Dashboard -> Edge Functions -> Secrets
# This is required for the `send-booking-email` function to work.
RESEND_API_KEY="your-resend-api-key"

# (Optional) If you are using any other third-party services like Stripe or Twilio later,
# their keys will go here as well.
